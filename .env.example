# Google Maps JS API key (public — loaded in browser)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Stadium coordinates (public)
NEXT_PUBLIC_STADIUM_LAT=33.7554
NEXT_PUBLIC_STADIUM_LNG=-84.4011
NEXT_PUBLIC_STADIUM_NAME=Mercedes-Benz Stadium

# MARTA train REST API key (server-only)
MARTA_TRAIN_API_KEY=

# Anthropic API key for Claude (server-only)
ANTHROPIC_API_KEY=

# Kill switches (optional — set to "true" to bypass live APIs)
USE_MOCK_CLAUDE=
USE_MOCK_MARTA_DATA=

# Static demo mode — skips all API calls, uses embedded mock data
# Required for GitHub Pages build and local dev (API routes removed)
NEXT_PUBLIC_STATIC_DEMO=true
